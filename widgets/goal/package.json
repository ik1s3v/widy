{
  "name": "goal",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:app": "rsbuild build -c rsbuild.config.app.ts",
    "build:obs": "rsbuild build -c rsbuild.config.obs.ts",
    "build:app:watch": "npm run build:app -- --watch",
    "build:obs:watch": "npm run build:obs -- --watch",
    "build:all": "npm run build:app && npm run build:obs",
    "check": "biome check --write",
    "dev": "rsbuild dev --open",
    "format": "biome format --write",
    "preview": "rsbuild preview"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "@widy/sdk": "^1.0.1",
    "@widy/react": "^1.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.0.6",
    "@rsbuild/core": "^1.4.3",
    "@rsbuild/plugin-react": "^1.3.3",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "typescript": "^5.8.3"
  }
}